{
    "Description":  "Train DeepSDF on planes (airplanes) - ShapeNet V2 02691156",
    "DataSource":  "./data/SdfSamples",
    "TrainSplit":  "examples/splits/planes_train.json",
    "TestSplit":  "examples/splits/planes_eval.json",
    "NetworkArch":  "deep_sdf_decoder",
    "NetworkSpecs":  {
                         "dims":  [
                                      512,
                                      512,
                                      512,
                                      512,
                                      512,
                                      512,
                                      512,
                                      512
                                  ],
                         "dropout":  [
                                         0,
                                         1,
                                         2,
                                         3,
                                         4,
                                         5,
                                         6,
                                         7
                                     ],
                         "dropout_prob":  0.2,
                         "norm_layers":  [
                                             0,
                                             1,
                                             2,
                                             3,
                                             4,
                                             5,
                                             6,
                                             7
                                         ],
                         "latent_in":  4,
                         "xyz_in_all":  false,
                         "use_tanh":  false,
                         "latent_dropout":  false,
                         "weight_norm":  true
                     },
    "CodeLength":  256,
    "NumEpochs":  1000,
    "SnapshotFrequency":  100,
    "AdditionalSnapshots":  [
                                10,
                                50
                            ],
    "LearningRateSchedule":  {
                                 "Type":  "Step",
                                 "Initial":  0.0005,
                                 "Interval":  500,
                                 "Factor":  0.5
                             },
    "SamplesPerScene":  16384,
    "ScenesPerBatch":  4,
    "DataLoaderThreads":  4,
    "ClampingDistance":  0.1,
    "CodeRegularization":  true,
    "CodeRegularizationLambda":  0.0001,
    "CodeBound":  1.0
}
